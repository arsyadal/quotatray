{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuotaTray",
  "version": "0.1.0",
  "identifier": "app.quotatray.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuotaTray",
        "width": 620,
        "height": 760,
        "minWidth": 320,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
